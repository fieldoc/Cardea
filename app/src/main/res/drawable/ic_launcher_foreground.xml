<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Cardea app icon — Direction D: gradient-filled parametric heart with white ECG line.
        Heart uses x=16sin^3(t), y=-(13cos-5cos2t-2cos3t-cos4t), centered at (54,53),
        scaled to fit adaptive icon safe zone (66dp circle within 108dp canvas).
    -->

    <!-- Gradient-filled heart -->
    <path
        android:pathData="
            M54,88
            C52,85.5 49.5,82 47,78.5
            C41,70 34.5,60 31,52
            C28.5,46.5 27,42 27,38
            C27,33 29,29 32.5,26.5
            C36,24 40.5,24 44.5,26
            C47,27 50,29.5 54,34
            C58,29.5 61,27 63.5,26
            C67.5,24 72,24 75.5,26.5
            C79,29 81,33 81,38
            C81,42 79.5,46.5 77,52
            C73.5,60 67,70 61,78.5
            C58.5,82 56,85.5 54,88 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="27"
                android:startY="24"
                android:endX="81"
                android:endY="88">
                <item android:offset="0.00" android:color="#FFFF5A5F"/>
                <item android:offset="0.35" android:color="#FFFF2DA6"/>
                <item android:offset="0.65" android:color="#FF5B5BFF"/>
                <item android:offset="1.00" android:color="#FF00D1FF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- White ECG waveform line through the heart -->
    <path
        android:pathData="
            M33,56
            L44,56
            L46.5,58
            L49,42
            L52.5,62
            L55,51
            L57,56.5
            L63,56
            L75,56"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#EEFFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

</vector>
