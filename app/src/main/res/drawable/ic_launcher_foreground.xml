<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Cardea app icon — Pure Signal.
        A medical ECG/heartbeat trace passes through the icon, bleeding off both edges.
        No heart shape is drawn — the heart is implied by the signal itself.
        Gradient: Red (#FF4D5A) → Pink (#FF2DA6) → Blue (#4D61FF) → Cyan (#00E5FF), left-to-right.
        QRS spike at x=47, reaching y=19 — nearly the full height of the icon.
    -->

    <!-- Glow corona: wide, very low opacity -->
    <path
        android:pathData="M-7,62 L28,62 L32,65 L36,50 L42,76 L47,19 L53,76 L57,59 L61,65 L70,62 L115,62"
        android:fillColor="@android:color/transparent"
        android:strokeWidth="16"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeAlpha="0.07">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="-7"  android:startY="62"
                android:endX="115"   android:endY="62">
                <item android:offset="0.00" android:color="#FFFF4D5A"/>
                <item android:offset="0.35" android:color="#FFFF2DA6"/>
                <item android:offset="0.65" android:color="#FF4D61FF"/>
                <item android:offset="1.00" android:color="#FF00E5FF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bloom: medium width, soft -->
    <path
        android:pathData="M-7,62 L28,62 L32,65 L36,50 L42,76 L47,19 L53,76 L57,59 L61,65 L70,62 L115,62"
        android:fillColor="@android:color/transparent"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeAlpha="0.18">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="-7"  android:startY="62"
                android:endX="115"   android:endY="62">
                <item android:offset="0.00" android:color="#FFFF4D5A"/>
                <item android:offset="0.35" android:color="#FFFF2DA6"/>
                <item android:offset="0.65" android:color="#FF4D61FF"/>
                <item android:offset="1.00" android:color="#FF00E5FF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main stroke: crisp, full opacity -->
    <path
        android:pathData="M-7,62 L28,62 L32,65 L36,50 L42,76 L47,19 L53,76 L57,59 L61,65 L70,62 L115,62"
        android:fillColor="@android:color/transparent"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="-7"  android:startY="62"
                android:endX="115"   android:endY="62">
                <item android:offset="0.00" android:color="#FFFF4D5A"/>
                <item android:offset="0.35" android:color="#FFFF2DA6"/>
                <item android:offset="0.65" android:color="#FF4D61FF"/>
                <item android:offset="1.00" android:color="#FF00E5FF"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
