{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(where kotlin-lsp:*)",
      "WebFetch(domain:github.com)",
      "Bash(echo $PATH:*)",
      "Bash(/c/tools/kotlin-lsp/kotlin-lsp.sh:*)",
      "Bash(/c/tools/kotlin-lsp/kotlin-lsp.cmd:*)",
      "Bash(python3:*)",
      "Bash(claude mcp:*)",
      "Bash(timeout 10 cmd:*)",
      "Bash(printf:*)",
      "Bash(export:*)",
      "Bash(echo exit: $?:*)",
      "Bash(kotlin-lsp:*)",
      "Bash(\"$JAVA_BIN\":*)",
      "Bash(\"/c/tools/kotlin-lsp/jre/bin/java\":*)",
      "Bash(xargs ls:*)",
      "Bash(echo:*)",
      "Bash(C:/Python314/python.exe:*)",
      "Bash(tasklist:*)",
      "Bash(wmic process:*)",
      "Bash(./gradlew.bat help:*)",
      "Bash(xargs cat:*)",
      "Bash(powershell.exe:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/check-commit-checklist.sh"
          }
        ]
      }
    ]
  }
}
