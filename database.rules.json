{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('users').child(auth.uid).child('partners').child($uid).exists()",
        ".write": "auth.uid === $uid",
        "partners": {
          "$partnerId": {
            ".write": "auth.uid === $uid || auth.uid === $partnerId",
            ".validate": "$partnerId !== $uid"
          }
        }
      }
    },
    "invites": {
      "$code": {
        ".read": true,
        ".write": "!data.exists() || data.child('userId').val() === auth.uid || (!newData.exists() && root.child('users').child(auth.uid).child('partners').child(data.child('userId').val()).exists())"
      }
    }
  }
}
